{
  "name": "rpc-bridge-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-platform RPC bridge framework using protobuf service definitions",
  "workspaces": [
    "packages/*",
    "demos/host-playground",
    "tests"
  ],
  "scripts": {
    "build": "npm run build:core && npm run build:codegen && npm run generate && npm run build:transports && npm run build:playground",
    "build:core": "cd packages/rpc-core && npm run build",
    "build:codegen": "cd packages/codegen && npm run build",
    "build:transports": "npm run build:transport-web && npm run build:transport-ios && npm run build:transport-android && npm run build:transport-electron",
    "build:transport-web": "cd packages/transport-web && npm run build",
    "build:transport-ios": "cd packages/transport-ios && npm run build",
    "build:transport-android": "cd packages/transport-android && npm run build",
    "build:transport-electron": "cd packages/transport-electron && npm run build",
    "build:playground": "cd demos/host-playground && npm run build",
    "generate": "cd packages/codegen && npm run generate",
    "test": "cd tests && npm test",
    "e2e:web": "npx playwright test --project=web",
    "e2e:electron": "npx playwright test --project=electron",
    "e2e:android": "npx playwright test --project=android",
    "clean": "rm -rf packages/*/dist packages/*/*.tsbuildinfo demos/host-playground/dist tests/dist"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "electron": "^41.2.0",
    "playwright": "^1.59.1",
    "typescript": "^5.4.0"
  }
}
